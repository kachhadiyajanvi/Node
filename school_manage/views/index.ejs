<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log in</title>
    <style>
        body{
            background-color: rgba(95, 158, 160,0.6);
        }
        .center{
            padding-top: 100px;
        }
        .header{
            font-family: cursive;
            color: blanchedalmond;
            text-align: center;
        
        }
        td{
            padding: 10px;
        }
        table{
            border:2px solid white;
        }
        input{
            padding: 5px 10px;
        }
        input:focus-visible {
            outline: none;
        }
        button{
            padding: 10px 20px;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: bold;
            color:gray;
        }
       .btn{
            text-align: center;
            padding-top: 30px !important;
       }
    </style>
</head>
<body>
    <form action="" method="post" class="center">
        <h1 class="header">Login Form</h1>
        <table cellpadding="0" cellspacing="0" align="center">
            <tr>
                <td>Name:=</td>
                <td><input type="Name" name="name" id=""  required></td>
            </tr>
            <tr>
                <td>Password:=</td>
                <td><input type="password" name="password" required></td>
            </tr>
            <tr>
                <td colspan="2" align="center"><button>Log In</button></td>
            </tr>
        </table>
    </form>
    <div class="btn">
        <a href="/student"><button>Show Result</button></a> 
    </div>
</body>
</html>